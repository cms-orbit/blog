{
    "name": "cms-orbit/blog",
    "version": "4.0.3",
    "description": "CMS Orbit blog sample container package.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "cms-orbit/core": "4.0.2",
        "cms-orbit/saas": "4.0.3",
        "laravel/framework": "^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "CmsOrbit\\Blog\\": "src/"
        },
        "classmap": [
            "container/themes/"
        ],
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "extra": {
        "orbit": {
            "container": "container"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
