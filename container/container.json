{
  "name": "Blog",
  "description": "블로그형 콘텐츠를 인스턴스로 운영하는 기본 컨테이너입니다.",
  "slug": "blog",
  "icon": "bs.pencil-square",
  "color": "#8b5cf6",
  "isolation": {
    "engine": "multi_database"
  },
  "routing": {
    "supports": ["domain", "subdomain", "path"],
    "default_subdomain": "blog",
    "path_first": true
  },
  "instance": {
    "theme_selectable": true,
    "auto_provision": {
      "enabled": false,
      "name": "Blog",
      "subdomain": "blog",
      "theme": "default"
    }
  },
  "admin": {
    "prefix": "admin",
    "sso_ttl_minutes": 30
  },
  "provider_namespace": "CmsOrbit\\Blog\\",
  "providers": [
    "CmsOrbit\\Blog\\BlogServiceProvider",
    "CmsOrbit\\Blog\\BlogInstanceAdminServiceProvider"
  ]
}
